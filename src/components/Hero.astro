<section class="relative bg-via-green overflow-hidden">
  <div class="absolute inset-0 bg-linear-to-br from-via-green-dark/30 to-transparent" aria-hidden="true"></div>

  <div class="relative max-w-6xl mx-auto px-4 py-16 md:py-24 text-center text-white">
    <p class="text-via-green-hover text-sm font-medium tracking-widest uppercase mb-3">
      — Desde 2011 —
    </p>
    <h1 class="text-3xl md:text-5xl font-bold font-display leading-tight mb-4">
      Asociación de Vida Independiente<br />Andalucía
    </h1>
    <p class="text-white/80 text-lg md:text-xl max-w-2xl mx-auto mb-8 font-light">
      Promoviendo la vida independiente y los derechos de las personas con diversidad funcional
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="/nosotros/"
        class="inline-flex items-center justify-center px-6 py-3 bg-white text-via-green font-semibold rounded-lg hover:bg-via-bg-alt transition-colors no-underline shadow-lg"
        tabindex="0"
        aria-label="Conocer nuestra filosofía"
      >
        Conoce nuestra filosofía
      </a>
      <a
        href="/contacto/"
        class="inline-flex items-center justify-center px-6 py-3 border-2 border-white text-white font-semibold rounded-lg hover:bg-white/10 transition-colors no-underline"
        tabindex="0"
        aria-label="Contactar con nosotros"
      >
        Contacto
      </a>
    </div>
  </div>
</section>
