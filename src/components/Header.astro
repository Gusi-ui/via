---
const currentPath = Astro.url.pathname;

type NavItem = {
  label: string;
  href: string;
  children?: NavItem[];
};

const navItems: NavItem[] = [
  { label: 'Nosotros', href: '/nosotros/' },
  { label: 'Recorrido Histórico', href: '/recorrido-historico/' },
  { label: 'Convención ONU', href: '/convencion/' },
  { label: 'Blog', href: '/posts/1/' },
  { label: 'Contacto', href: '/contacto/' },
];

const isActive = (href: string) => {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
};
---

<header class="sticky top-0 z-50 bg-via-bg-content text-via-text border-b border-via-divider">
  <nav class="max-w-6xl mx-auto px-4 relative" aria-label="Navegación principal">
    <div class="flex items-center justify-between h-20">
      <a
        href="/"
        class="flex items-center gap-3 no-underline group rounded-xl px-1.5 py-1.5 hover:bg-via-bg-alt transition-colors focus:outline-none focus:ring-2 focus:ring-via-green/60"
        aria-label="Ir al inicio - OVIAndalucía"
        tabindex="0"
      >
        <img
          src="/logo.avif"
          alt="Oficina de Vida Independiente Andalucía"
          class="h-16 w-auto max-w-[420px] object-contain"
          loading="eager"
        />
        <span class="sr-only">OVIAndalucía</span>
      </a>

      <button
        id="mobile-menu-toggle"
        class="md:hidden p-2 text-via-green hover:bg-via-green/10 rounded-xl focus:outline-none focus:ring-2 focus:ring-via-green/35"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Abrir menú de navegación"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          <path id="close-icon" class="hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      <ul class="hidden md:flex items-center gap-4" role="menubar" aria-label="Secciones">
        {navItems.map((item) => (
          <li class="relative group" role="none">
            <a
              href={item.href}
              role="menuitem"
              class:list={[
                'inline-flex items-center gap-2 px-3 py-2 rounded-xl text-[16px] font-ui font-semibold transition-colors no-underline whitespace-nowrap focus:outline-none focus:ring-2 focus:ring-via-green/35',
                isActive(item.href)
                  ? 'bg-via-green text-white! shadow-sm hover:bg-via-green/90'
                  : 'bg-transparent text-via-green! hover:bg-via-green hover:text-white!',
              ]}
              aria-current={isActive(item.href) ? 'page' : undefined}
              tabindex="0"
              aria-label={item.label}
            >
              {item.label}
              {item.children && (
                <svg class="w-4 h-4 inline-block" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              )}
            </a>
            {item.children && (
              <ul
                class="absolute left-0 mt-2 w-64 bg-via-bg-content rounded-2xl shadow-xl border border-via-divider/60 opacity-0 invisible group-hover:opacity-100 group-hover:visible group-focus-within:opacity-100 group-focus-within:visible transition-all duration-200 py-2 z-50"
                role="menu"
              >
                {item.children.map((child) => (
                  <li role="none">
                    <a
                      href={child.href}
                      role="menuitem"
                      aria-label={`Ir a ${child.label}`}
                      class="block mx-2 px-4 py-2.5 text-sm font-semibold text-via-green! hover:bg-via-green/10 hover:text-via-green-dark! transition-colors no-underline rounded-xl focus:outline-none focus:ring-2 focus:ring-via-green/60"
                      tabindex="0"
                    >
                      {child.label}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ul>
    </div>

      <div
        id="mobile-menu"
        class="hidden absolute left-2 right-2 top-full mt-3 z-50 pb-4 md:hidden bg-via-bg-content border border-via-divider/60 rounded-2xl shadow-xl"
        role="menu"
        aria-label="Menú móvil"
      >
      {navItems.map((item) => (
        <>
          <a
            href={item.href}
            role="menuitem"
            class:list={[
              'block px-3 py-2 rounded-xl text-base font-ui font-semibold transition-colors no-underline',
              isActive(item.href)
                ? 'bg-via-green text-white'
                : 'bg-transparent text-via-green! hover:bg-via-green hover:text-white!',
            ]}
            tabindex="0"
              aria-label={item.label}
          >
            {item.label}
          </a>
          {item.children?.map((child) => (
          <a
            href={child.href}
            role="menuitem"
              class="block pl-6 pr-3 py-1.5 text-sm font-medium text-via-green! hover:bg-via-green/10 hover:text-via-green-dark! transition-colors no-underline rounded-xl"
            tabindex="0"
            aria-label={child.label}
          >
              {child.label}
            </a>
          ))}
        </>
      ))}
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');

  const closeMenu = () => {
    if (!toggle || !menu) return;
    toggle.setAttribute('aria-expanded', 'false');
    menu.classList.add('hidden');
    menuIcon?.classList.remove('hidden');
    closeIcon?.classList.add('hidden');
  };

  const openMenu = () => {
    if (!toggle || !menu) return;
    toggle.setAttribute('aria-expanded', 'true');
    menu.classList.remove('hidden');
    menuIcon?.classList.add('hidden');
    closeIcon?.classList.remove('hidden');
  };

  toggle?.addEventListener('click', () => {
    const isExpanded = toggle.getAttribute('aria-expanded') === 'true';
    if (isExpanded) closeMenu();
    else openMenu();
  });

  // Cierra el menú cuando se selecciona una opción (mejora consistencia y UX).
  menu?.querySelectorAll('a[href]').forEach((link) => {
    link.addEventListener('click', () => closeMenu());
  });
</script>
