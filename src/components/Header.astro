---
const currentPath = Astro.url.pathname;

type NavItem = {
  label: string;
  href: string;
  children?: NavItem[];
};

const navItems: NavItem[] = [
  { label: 'Inicio', href: '/' },
  { label: 'Nosotros', href: '/nosotros/' },
  { label: 'Recorrido Histórico', href: '/recorrido-historico/' },
  { label: 'Convención ONU', href: '/convencion/' },
  {
    label: 'Categorías',
    href: '/category/noticias/1/',
    children: [
      { label: 'Noticias', href: '/category/noticias/1/' },
      { label: 'Asistencia Personal', href: '/category/asistencia-personal/1/' },
      { label: 'Artículos', href: '/category/articulos/1/' },
      { label: 'Denuncias', href: '/category/denuncias/1/' },
      { label: 'Notas de Prensa', href: '/category/notas-de-prensa-2/1/' },
      { label: 'Opinión', href: '/category/opinion/1/' },
      { label: 'VIAndalucía', href: '/category/viandalucia/1/' },
      { label: 'Relatos AP', href: '/category/relatos-ap/1/' },
      { label: 'Legislación', href: '/category/legislacion/1/' },
    ],
  },
  { label: 'Contacto', href: '/contacto/' },
];

const isActive = (href: string) => {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
};
---

<header class="sticky top-0 z-50 bg-via-bg-content shadow-md">
  <div class="bg-via-topbar text-white text-sm py-1 hidden md:block">
    <div class="max-w-6xl mx-auto px-4 flex justify-end gap-4">
      <a
        href="mailto:viandalucia@viandalucia.org"
        class="text-white/80 hover:text-white transition-colors no-underline"
        aria-label="Enviar email a VIAndalucía"
      >
        viandalucia@viandalucia.org
      </a>
    </div>
  </div>

  <nav class="max-w-6xl mx-auto px-4" aria-label="Navegación principal">
    <div class="flex items-center justify-between h-16">
      <a
        href="/"
        class="flex items-center gap-3 no-underline group"
        aria-label="Ir al inicio - OVIAndalucía"
      >
        <span class="text-xl font-bold text-via-green font-display tracking-tight group-hover:text-via-green-dark transition-colors">
          OVI<span class="text-via-text">Andalucía</span>
        </span>
      </a>

      <button
        id="mobile-menu-toggle"
        class="md:hidden p-2 text-via-text hover:text-via-green rounded-lg focus:outline-none focus:ring-2 focus:ring-via-green"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Abrir menú de navegación"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          <path id="close-icon" class="hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      <ul class="hidden md:flex items-center gap-1" role="menubar">
        {navItems.map((item) => (
          <li class="relative group" role="none">
            <a
              href={item.href}
              role="menuitem"
              class:list={[
                'block px-3 py-2 rounded-md text-sm font-medium transition-colors no-underline',
                isActive(item.href)
                  ? 'bg-via-green text-white'
                  : 'text-via-text hover:bg-via-green/10 hover:text-via-green',
              ]}
              aria-current={isActive(item.href) ? 'page' : undefined}
              tabindex="0"
            >
              {item.label}
              {item.children && (
                <svg class="w-3 h-3 ml-1 inline-block" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              )}
            </a>
            {item.children && (
              <ul
                class="absolute left-0 mt-0 w-56 bg-via-bg-content rounded-lg shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 py-2 z-50"
                role="menu"
              >
                {item.children.map((child) => (
                  <li role="none">
                    <a
                      href={child.href}
                      role="menuitem"
                      class="block px-4 py-2 text-sm text-via-text hover:bg-via-green/10 hover:text-via-green transition-colors no-underline"
                      tabindex="0"
                    >
                      {child.label}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ul>
    </div>

    <div id="mobile-menu" class="hidden md:hidden pb-4" role="menu">
      {navItems.map((item) => (
        <>
          <a
            href={item.href}
            role="menuitem"
            class:list={[
              'block px-3 py-2 rounded-md text-base font-medium transition-colors no-underline',
              isActive(item.href)
                ? 'bg-via-green text-white'
                : 'text-via-text hover:bg-via-green/10 hover:text-via-green',
            ]}
            tabindex="0"
          >
            {item.label}
          </a>
          {item.children?.map((child) => (
            <a
              href={child.href}
              role="menuitem"
              class="block pl-6 pr-3 py-1.5 text-sm text-via-text-meta hover:text-via-green transition-colors no-underline"
              tabindex="0"
            >
              {child.label}
            </a>
          ))}
        </>
      ))}
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');

  toggle?.addEventListener('click', () => {
    const isExpanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!isExpanded));
    menu?.classList.toggle('hidden');
    menuIcon?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
  });
</script>
