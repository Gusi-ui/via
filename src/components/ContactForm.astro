---

---

<form id="contact-form" class="space-y-5" novalidate>
  <div>
    <label for="name" class="block text-sm font-medium text-via-text mb-1">
      Nombre <span class="text-red-500" aria-hidden="true">*</span>
    </label>
    <input
      type="text"
      id="name"
      name="name"
      required
      autocomplete="name"
      class="w-full px-4 py-2.5 border border-via-divider rounded-lg bg-via-bg-alt text-via-text focus:ring-2 focus:ring-via-green focus:border-via-green outline-none transition-colors"
      aria-required="true"
    />
  </div>

  <div>
    <label for="email" class="block text-sm font-medium text-via-text mb-1">
      Email <span class="text-red-500" aria-hidden="true">*</span>
    </label>
    <input
      type="email"
      id="email"
      name="email"
      required
      autocomplete="email"
      class="w-full px-4 py-2.5 border border-via-divider rounded-lg bg-via-bg-alt text-via-text focus:ring-2 focus:ring-via-green focus:border-via-green outline-none transition-colors"
      aria-required="true"
    />
  </div>

  <div>
    <label for="message" class="block text-sm font-medium text-via-text mb-1">
      Mensaje <span class="text-red-500" aria-hidden="true">*</span>
    </label>
    <textarea
      id="message"
      name="message"
      rows="5"
      required
      class="w-full px-4 py-2.5 border border-via-divider rounded-lg bg-via-bg-alt text-via-text focus:ring-2 focus:ring-via-green focus:border-via-green outline-none transition-colors resize-y"
      aria-required="true"
    ></textarea>
  </div>

  <div class="flex items-start gap-2">
    <input
      type="checkbox"
      id="privacy"
      name="privacy"
      required
      class="mt-1 w-4 h-4 text-via-green border-via-divider rounded focus:ring-via-green"
      aria-required="true"
    />
    <label for="privacy" class="text-sm text-via-text-meta">
      He leído y acepto la <a href="/aviso-legal/" class="text-via-link hover:text-via-link-hover underline">política de privacidad</a>
      <span class="text-red-500" aria-hidden="true">*</span>
    </label>
  </div>

  <div id="form-status" class="hidden text-sm p-3 rounded-lg" role="alert"></div>

  <button
    type="submit"
    class="w-full sm:w-auto px-8 py-3 bg-via-green text-white font-semibold rounded-xl border border-via-green hover:bg-white hover:text-via-green focus:outline-none focus:ring-2 focus:ring-via-green/40 transition-colors cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed"
  >
    Enviar mensaje
  </button>
</form>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const status = document.getElementById('form-status') as HTMLDivElement;

  const handleSubmit = async (e: Event) => {
    e.preventDefault();

    const formData = new FormData(form);
    const name = formData.get('name') as string;
    const email = formData.get('email') as string;
    const message = formData.get('message') as string;
    const privacy = formData.get('privacy');

    if (!name || !email || !message || !privacy) {
      status.textContent = 'Por favor, rellena todos los campos obligatorios.';
      status.className = 'text-sm p-3 rounded-lg bg-red-50 text-red-700 border border-red-200';
      return;
    }

    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailRegex.test(email)) {
      status.textContent = 'Por favor, introduce un email válido.';
      status.className = 'text-sm p-3 rounded-lg bg-red-50 text-red-700 border border-red-200';
      return;
    }

    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    submitBtn.disabled = true;
    submitBtn.textContent = 'Enviando...';

    try {
      const response = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, email, message }),
      });

      const result = await response.json();

      if (response.ok) {
        status.textContent = 'Mensaje enviado correctamente. Gracias por contactarnos.';
        status.className = 'text-sm p-3 rounded-lg bg-green-50 text-green-700 border border-green-200';
        form.reset();
      } else {
        status.textContent = result.error || 'Error al enviar el mensaje. Inténtalo de nuevo.';
        status.className = 'text-sm p-3 rounded-lg bg-red-50 text-red-700 border border-red-200';
      }
    } catch {
      status.textContent = 'Error de conexión. Inténtalo de nuevo más tarde.';
      status.className = 'text-sm p-3 rounded-lg bg-red-50 text-red-700 border border-red-200';
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Enviar mensaje';
    }
  };

  form?.addEventListener('submit', handleSubmit);
</script>
