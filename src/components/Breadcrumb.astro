---
type BreadcrumbItem = {
  label: string;
  href?: string;
};

type Props = {
  items: BreadcrumbItem[];
};

const { items } = Astro.props;
---

<nav aria-label="Migas de pan" class="text-sm text-via-text-secondary">
  <ol class="flex flex-wrap items-center gap-1" role="list">
    {items.map((item, index) => (
      <li class="flex items-center gap-1">
        {index > 0 && (
          <svg class="w-3 h-3 text-via-divider shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        )}
        {item.href ? (
          <a
            href={item.href}
            class="hover:text-via-green transition-colors no-underline"
            tabindex="0"
          >
            {item.label}
          </a>
        ) : (
          <span class="text-via-text font-medium" aria-current="page">{item.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>
