---
import { getAllCategories, getAllTags, getPublishedPosts } from '@/lib/collections';

const categories = await getAllCategories();
const tags = await getAllTags();
const recentPosts = (await getPublishedPosts()).slice(0, 6);
---

<div class="space-y-6 lg:sticky lg:top-24">
  <div class="bg-via-bg-content rounded-xl shadow-sm p-5">
    <h3 class="text-lg font-bold font-serif text-via-green mb-4 pb-2 border-b-2 border-via-divider">
      Páginas Amigas
    </h3>
    <div class="grid grid-cols-2 gap-3">
      <a
        href="https://www.asociacionsolcom.org/"
        class="group rounded-xl border border-via-divider bg-white p-3 flex items-center justify-center hover:bg-via-bg-alt transition-colors"
        target="_blank"
        rel="noreferrer"
      >
        <img
          src="https://viandalucia.org/wp-content/uploads/2019/05/logo_solcom.png"
          alt="Solcom"
          class="h-10 w-auto opacity-85 group-hover:opacity-100 transition-opacity"
          loading="lazy"
        />
      </a>
      <a
        href="https://www.derechoshumanosya.org/"
        class="group rounded-xl border border-via-divider bg-white p-3 flex items-center justify-center hover:bg-via-bg-alt transition-colors"
        target="_blank"
        rel="noreferrer"
      >
        <img
          src="https://viandalucia.org/wp-content/uploads/2019/05/logo_dhy.png"
          alt="Derechos Humanos Ya"
          class="h-10 w-auto opacity-85 group-hover:opacity-100 transition-opacity"
          loading="lazy"
        />
      </a>
      <a
        href="https://www.federacionvi.org/"
        class="group rounded-xl border border-via-divider bg-white p-3 flex items-center justify-center hover:bg-via-bg-alt transition-colors"
        target="_blank"
        rel="noreferrer"
      >
        <img
          src="https://viandalucia.org/wp-content/uploads/2019/05/logo_fevi.png"
          alt="Federación de Vida Independiente"
          class="h-10 w-auto opacity-85 group-hover:opacity-100 transition-opacity"
          loading="lazy"
        />
      </a>
      <a
        href="https://enil.eu/"
        class="group rounded-xl border border-via-divider bg-white p-3 flex items-center justify-center hover:bg-via-bg-alt transition-colors"
        target="_blank"
        rel="noreferrer"
      >
        <img
          src="https://viandalucia.org/wp-content/uploads/2019/07/logoenil.png"
          alt="ENIL"
          class="h-10 w-auto opacity-85 group-hover:opacity-100 transition-opacity"
          loading="lazy"
        />
      </a>
    </div>
  </div>

  <div class="bg-via-bg-content rounded-xl shadow-sm p-5">
    <h3 class="text-lg font-bold font-serif text-via-green mb-4 pb-2 border-b-2 border-via-divider">
      Documental «A Volar»
    </h3>
    <div class="rounded-xl overflow-hidden border border-via-divider bg-black">
      <div class="relative w-full pb-[56.25%]">
        <iframe
          class="absolute inset-0 w-full h-full"
          src="https://www.youtube.com/embed/_2BH6zJtyPc?si=3iDIXZnK1VfB35ZV"
          title="Documental A Volar"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          referrerpolicy="strict-origin-when-cross-origin"
          allowfullscreen
        />
      </div>
    </div>
    <p class="text-sm text-via-text-meta mt-3">
      Un documental que narra, a través de confesiones íntimas, la historia de discriminación y esperanza de
      personas con diversidad funcional en Andalucía.
    </p>
  </div>

  <div class="bg-via-bg-content rounded-xl shadow-sm p-5">
    <h3 class="text-lg font-bold font-serif text-via-green mb-4 pb-2 border-b-2 border-via-divider">
      Programa OVIA
    </h3>
    <a
      href="/posts/estudio-universitario-muestra-el-exito-de-la-asistencia-personal/"
      class="block rounded-xl overflow-hidden border border-via-divider hover:bg-via-bg-alt transition-colors no-underline"
    >
      <img
        src="https://viandalucia.org/wp-content/uploads/2019/06/proyectovi.jpg"
        alt="Programa Vida Independiente"
        class="w-full h-44 object-cover"
        loading="lazy"
      />
      <div class="p-3">
        <div class="text-sm font-medium text-via-text">Evaluación externa (UPO)</div>
        <div class="text-xs text-via-text-secondary mt-1">
          Lee el artículo sobre la evaluación externa del programa.
        </div>
      </div>
    </a>
  </div>

  <div class="bg-via-bg-content rounded-xl shadow-sm p-5">
    <h3 class="text-lg font-bold font-serif text-via-green mb-4 pb-2 border-b-2 border-via-divider">
      Imprescindibles
    </h3>
    <a
      href="/bibliografia-de-fondo/"
      class="block rounded-xl overflow-hidden border border-via-divider hover:bg-via-bg-alt transition-colors no-underline"
    >
      <img
        src="https://viandalucia.org/wp-content/uploads/2019/06/portadas-libros.jpg"
        alt="Bibliografía imprescindible"
        class="w-full h-44 object-cover"
        loading="lazy"
      />
      <div class="p-3">
        <div class="text-sm font-medium text-via-text">Bibliografía de fondo</div>
        <div class="text-xs text-via-text-secondary mt-1">
          Libros con breve descripción y descarga en PDF.
        </div>
      </div>
    </a>
  </div>

  <div class="bg-via-bg-content rounded-xl shadow-sm p-5">
    <h3 class="text-lg font-bold font-serif text-via-green mb-4 pb-2 border-b-2 border-via-divider">
      Últimas entradas
    </h3>
    <ul class="space-y-3" role="list">
      {recentPosts.map((post) => (
        <li>
          <a
            href={`/posts/${post.id}/`}
            class="block rounded-lg px-2 py-1.5 hover:bg-via-green/10 transition-colors no-underline"
            tabindex="0"
          >
            <div class="text-sm text-via-text font-medium leading-snug">{post.data.title}</div>
            <div class="text-xs text-via-text-secondary mt-1">
              {post.data.categories?.[0]?.replace(/-/g, ' ')}
            </div>
          </a>
        </li>
      ))}
    </ul>
  </div>

  <div class="bg-via-bg-content rounded-xl shadow-sm p-5">
    <h3 class="text-lg font-bold font-serif text-via-green mb-4 pb-2 border-b-2 border-via-divider">
      Categorías
    </h3>
    <ul class="space-y-1.5" role="list">
      {categories.map((cat) => (
        <li>
          <a
            href={`/category/${cat.name}/1/`}
            class="flex justify-between items-center py-1.5 px-2 rounded-md text-sm text-via-text hover:bg-via-green/10 hover:text-via-green transition-colors no-underline"
            tabindex="0"
          >
            <span class="capitalize">{cat.name.replace(/-/g, ' ')}</span>
            <span class="text-xs text-via-text-secondary bg-via-bg-alt px-2 py-0.5 rounded-full">
              {cat.count}
            </span>
          </a>
        </li>
      ))}
    </ul>
  </div>

  <div class="bg-via-bg-content rounded-xl shadow-sm p-5">
    <h3 class="text-lg font-bold font-serif text-via-green mb-4 pb-2 border-b-2 border-via-divider">
      Etiquetas
    </h3>
    <div class="flex flex-wrap gap-2">
      {tags.slice(0, 14).map((tag) => (
        <a
          href={`/tag/${tag.name}/1/`}
          class="text-xs bg-via-bg-alt text-via-text-meta px-2.5 py-1 rounded-full hover:bg-via-green/10 hover:text-via-green transition-colors no-underline"
          tabindex="0"
        >
          #{tag.name}
        </a>
      ))}
    </div>
  </div>

  <div class="bg-via-bg-content rounded-xl shadow-sm p-5">
    <h3 class="text-lg font-bold font-serif text-via-green mb-4 pb-2 border-b-2 border-via-divider">
      Convención ONU
    </h3>
    <p class="text-sm text-via-text-meta mb-3">
      Convención sobre los derechos de las personas con discapacidad
    </p>
    <a
      href="/convencion/"
      class="inline-flex items-center gap-1 text-sm font-medium text-via-link hover:text-via-link-hover transition-colors no-underline"
      tabindex="0"
    >
      Ver todos los artículos
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </a>
  </div>
</div>
