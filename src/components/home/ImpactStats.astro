---
type Stat = {
  number: string;
  label: string;
  icon: string;
};

const stats: Stat[] = [
  {
    number: '2011',
    label: 'Año de fundación',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />',
  },
  {
    number: '264+',
    label: 'Artículos publicados',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />',
  },
  {
    number: '50',
    label: 'Artículos de la Convención ONU',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" />',
  },
  {
    number: '9+',
    label: 'Categorías temáticas',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />',
  },
];
---

<section class="py-16 md:py-20 bg-via-green relative overflow-hidden" aria-labelledby="stats-heading">
  <div class="absolute inset-0" aria-hidden="true">
    <div class="absolute inset-0 bg-linear-to-br from-via-green-dark/20 to-transparent"></div>
    <div class="absolute top-0 left-1/4 w-72 h-72 rounded-full bg-white/5"></div>
    <div class="absolute bottom-0 right-1/3 w-56 h-56 rounded-full bg-white/3"></div>
  </div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 relative z-10">
    <div class="text-center mb-12">
      <h2 id="stats-heading" class="text-3xl md:text-4xl font-bold font-serif text-white mb-3">
        Nuestro impacto
      </h2>
      <p class="text-white/75 text-lg max-w-xl mx-auto">
        Más de una década trabajando por los derechos de las personas con diversidad funcional
      </p>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
      {stats.map((stat) => (
        <div class="text-center p-6 rounded-2xl bg-white/10 backdrop-blur-sm border border-white/10 hover:bg-white/15 transition-colors duration-300">
          <div class="w-12 h-12 rounded-xl bg-white/10 flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-via-green-hover" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <g set:html={stat.icon} />
            </svg>
          </div>
          <p class="text-3xl md:text-4xl font-bold font-display text-white mb-1">
            {stat.number}
          </p>
          <p class="text-sm text-white/70 leading-snug">{stat.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>
