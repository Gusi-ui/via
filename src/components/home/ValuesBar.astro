---
type Value = {
  icon: string;
  label: string;
  description: string;
};

const values: Value[] = [
  {
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />',
    label: 'Dignidad',
    description: 'Respeto inherente a toda persona',
  },
  {
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" />',
    label: 'Igualdad',
    description: 'Mismas oportunidades para todos',
  },
  {
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />',
    label: 'Autodeterminación',
    description: 'Control sobre tu propia vida',
  },
];
---

<section class="relative -mt-1 bg-via-bg py-10 md:py-14" aria-label="Valores fundamentales">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
      {values.map((value) => (
        <div class="flex items-start gap-4 p-5 rounded-xl bg-via-bg-content shadow-sm hover:shadow-md transition-shadow duration-300 border border-via-divider/50">
          <div class="shrink-0 w-12 h-12 rounded-xl bg-via-green/10 flex items-center justify-center">
            <svg class="w-6 h-6 text-via-green" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <g set:html={value.icon} />
            </svg>
          </div>
          <div>
            <h3 class="text-lg font-bold font-serif text-via-green mb-1">{value.label}</h3>
            <p class="text-sm text-via-text-meta leading-relaxed">{value.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
