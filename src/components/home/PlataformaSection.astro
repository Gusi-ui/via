---

---

<section class="py-16 md:py-20 bg-via-bg relative overflow-hidden" aria-labelledby="plataforma-heading">
  <div class="absolute top-0 right-0 w-96 h-96 bg-via-green/5 rounded-full -translate-y-1/2 translate-x-1/2" aria-hidden="true"></div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 relative">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
      <!-- Contenido -->
      <div>
        <span class="inline-block text-sm font-semibold text-via-accent tracking-widest uppercase mb-3">
          Iniciativa conjunta
        </span>
        <h2 id="plataforma-heading" class="text-3xl md:text-4xl font-bold font-serif text-via-green mb-5 leading-tight">
          Plataforma por una Asistencia Personal Real
        </h2>
        <p class="text-via-text text-lg leading-relaxed mb-4">
          Vida Independiente Andalucía, junto con <strong>Asense-A</strong> y
          <strong>Trapecistas en la Ciudad</strong>, nos hemos unido para constituir la
          Plataforma por una Asistencia Personal Real.
        </p>
        <p class="text-via-text-meta leading-relaxed mb-8">
          Juntas reclamamos una asistencia personal que responda verdaderamente a las
          necesidades de las personas con diversidad funcional, no como un privilegio
          sino como un derecho fundamental.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href="https://youtu.be/DqvhK780MHc"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-3 px-6 py-3.5 bg-via-green text-white font-semibold rounded-xl border border-via-green hover:bg-white hover:text-via-green transition-all duration-300 no-underline shadow-md hover:shadow-lg focus:outline-none focus:ring-2 focus:ring-via-green/40"
            tabindex="0"
            aria-label="Ver el vídeo de la Plataforma en YouTube (se abre en nueva ventana)"
          >
            <span class="w-10 h-10 rounded-full bg-white/20 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 ml-0.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M8 5v14l11-7z" />
              </svg>
            </span>
            Ver nuestro vídeo
          </a>
          <a
            href="/category/asistencia-personal/1/"
            class="inline-flex items-center justify-center gap-2 px-6 py-3.5 border-2 border-via-green/30 text-via-green font-semibold rounded-xl hover:bg-via-green/5 hover:border-via-green/50 transition-all duration-300 no-underline"
            tabindex="0"
          >
            Más sobre Asistencia Personal
          </a>
        </div>
      </div>

      <!-- Visual card -->
      <div class="relative" aria-hidden="true">
        <div class="bg-via-bg-content rounded-2xl shadow-lg border border-via-divider/30 p-8 relative overflow-hidden">
          <div class="absolute top-0 left-0 w-full h-1.5 bg-linear-to-r from-via-green via-via-accent to-via-green-light"></div>
          <div class="space-y-6">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-xl bg-via-green/10 flex items-center justify-center shrink-0">
                <svg class="w-6 h-6 text-via-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                </svg>
              </div>
              <div>
                <p class="font-bold text-via-text">VIAndalucía</p>
                <p class="text-sm text-via-text-meta">Vida Independiente Andalucía</p>
              </div>
            </div>
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-xl bg-via-accent/10 flex items-center justify-center shrink-0">
                <svg class="w-6 h-6 text-via-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <p class="font-bold text-via-text">Asense-A</p>
                <p class="text-sm text-via-text-meta">Asociación aliada</p>
              </div>
            </div>
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-xl bg-via-green-light/10 flex items-center justify-center shrink-0">
                <svg class="w-6 h-6 text-via-green-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <p class="font-bold text-via-text">Trapecistas en la Ciudad</p>
                <p class="text-sm text-via-text-meta">Accesibilidad universal</p>
              </div>
            </div>
          </div>
          <div class="mt-6 pt-6 border-t border-via-divider/50">
            <p class="text-sm text-via-text-secondary italic text-center">
              "Unidos por una asistencia personal que sea un derecho, no un privilegio"
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
