---

---

<section class="py-16 md:py-20 bg-via-bg relative overflow-hidden" aria-labelledby="cta-heading">
  <div class="absolute inset-0" aria-hidden="true">
    <div class="absolute -top-20 -left-20 w-80 h-80 rounded-full bg-via-green/5"></div>
    <div class="absolute -bottom-20 -right-20 w-96 h-96 rounded-full bg-via-green/3"></div>
  </div>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 relative z-10">
    <div class="bg-via-bg-content rounded-3xl shadow-lg border border-via-divider/30 p-8 md:p-12 text-center relative overflow-hidden">
      <div class="absolute top-0 left-0 w-full h-1 bg-linear-to-r from-via-green via-via-green-light to-via-accent" aria-hidden="true"></div>

      <div class="w-16 h-16 rounded-2xl bg-via-green/10 flex items-center justify-center mx-auto mb-6">
        <svg class="w-8 h-8 text-via-green" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
        </svg>
      </div>

      <h2 id="cta-heading" class="text-2xl md:text-3xl font-bold font-serif text-via-green mb-4">
        ¿Quieres formar parte del cambio?
      </h2>
      <p class="text-via-text-meta text-lg max-w-xl mx-auto mb-8 leading-relaxed">
        Únete a nuestra lucha por la vida independiente. Cada voz cuenta para construir
        una sociedad más justa e inclusiva.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/contacto/"
          class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-via-green text-white font-semibold rounded-xl hover:bg-via-green-dark transition-all duration-300 no-underline shadow-md hover:shadow-lg text-base"
          tabindex="0"
          aria-label="Contactar con la asociación"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          Contáctanos
        </a>
        <a
          href="/nosotros/"
          class="inline-flex items-center justify-center gap-2 px-8 py-4 border-2 border-via-green/30 text-via-green font-semibold rounded-xl hover:bg-via-green/5 hover:border-via-green/50 transition-all duration-300 no-underline text-base"
          tabindex="0"
        >
          Conoce nuestra filosofía
        </a>
      </div>
    </div>
  </div>
</section>
