---
type ProgramDay = {
  dateLabel: string;
  parts: ProgramPart[];
};

type ProgramPart = {
  label: string;
  items: ProgramItem[];
};

type ProgramItem = {
  time?: string;
  title: string;
  href?: string;
  speaker?: string;
};

