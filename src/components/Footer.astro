const arrowIcon = `<svg class="w-3.5 h-3.5 shrink-0 opacity-40 group-hover:opacity-80 group-hover:translate-x-0.5 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>`;
---

<footer class="bg-via-green text-white mt-12">
  <div class="max-w-6xl mx-auto px-4 py-8 sm:py-10 md:py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">

      <!-- Col 1: identidad -->
      <div class="flex flex-col">
        <h3 class="text-lg font-bold text-white mb-3 font-display">OVIAndalucía</h3>
        <p class="text-white/80 text-sm leading-relaxed">
          Oficina de Vida Independiente Andalucía. Trabajamos por los derechos
          y la autonomía de las personas con diversidad funcional desde 2011.
        </p>
        <!-- Links de identidad -->
        <div class="mt-4 border-t border-white/15 pt-3 flex flex-col gap-1.5">
          <p class="text-white/55 text-xs font-semibold tracking-wide uppercase mb-1">Conócenos</p>
          <a href="/nosotros/" class="group flex items-center justify-between text-white/85 hover:text-white no-underline text-sm py-1 transition-colors">
            <span>Quiénes somos</span>
            <Fragment set:html={arrowIcon} />
          </a>
          <a href="/recorrido-historico/" class="group flex items-center justify-between text-white/85 hover:text-white no-underline text-sm py-1 transition-colors">
            <span>Nuestra historia</span>
            <Fragment set:html={arrowIcon} />
          </a>
        </div>
      </div>

      <!-- Col 2: contacto -->
      <div class="flex flex-col">
        <h3 class="text-lg font-bold text-white mb-3 font-display">Contacto</h3>
        <div class="flex flex-col gap-2">
          <!-- Email -->
          <a
            href="mailto:viandalucia@viandalucia.org"
            class="group flex items-center gap-2.5 rounded-xl px-3 py-3 bg-white/10 text-white hover:bg-white hover:text-via-green transition-colors no-underline"
          >
            <svg class="w-4 h-4 shrink-0 opacity-70 group-hover:opacity-100" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="4" width="20" height="16" rx="2"/>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
            <span class="text-sm font-medium">viandalucia@viandalucia.org</span>
          </a>
          <!-- Formulario -->
          <a
            href="/contacto/"
            class="group flex items-center justify-between gap-2 rounded-xl px-3 py-3 bg-white/10 text-white hover:bg-white hover:text-via-green transition-colors no-underline"
          >
            <span class="text-sm font-semibold">Formulario de contacto</span>
            <svg class="w-4 h-4 shrink-0 opacity-60 group-hover:opacity-100 group-hover:translate-x-0.5 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
        <!-- Recursos -->
        <div class="mt-4 border-t border-white/15 pt-3 flex flex-col gap-1.5">
          <p class="text-white/55 text-xs font-semibold tracking-wide uppercase mb-1">Recursos</p>
          <a href="/convencion/" class="group flex items-center justify-between text-white/85 hover:text-white no-underline text-sm py-1 transition-colors">
            <span>Convención ONU sobre discapacidad</span>
            <Fragment set:html={arrowIcon} />
          </a>
          <a href="/posts/1/" class="group flex items-center justify-between text-white/85 hover:text-white no-underline text-sm py-1 transition-colors">
            <span>Bitácora</span>
            <Fragment set:html={arrowIcon} />
          </a>
        </div>
      </div>

      <!-- Col 3: redes sociales -->
      <div class="flex flex-col">
        <h3 class="text-lg font-bold text-white mb-3 font-display">Síguenos en la red</h3>
        <div class="grid grid-cols-2 gap-2">
          {socialLinks.map((link) => (
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              class="group flex items-center gap-2 rounded-xl px-3 py-3 bg-white/10 text-white hover:bg-white hover:text-via-green transition-colors no-underline"
              aria-label={`Visitar ${link.name}`}
            >
              <svg class="w-4 h-4 fill-current shrink-0 opacity-80 group-hover:opacity-100" viewBox="0 0 24 24" aria-hidden="true">
                <path d={link.icon} />
              </svg>
              <span class="text-sm font-semibold">{link.name}</span>
            </a>
          ))}
        </div>
        <!-- Plataforma -->
        <div class="mt-4 border-t border-white/15 pt-3 flex flex-col gap-1.5">
          <p class="text-white/55 text-xs font-semibold tracking-wide uppercase mb-1">También en</p>
          <a
            href="https://www.youtube.com/@plataformaporunaasistencia6509"
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-center justify-between text-white/85 hover:text-white no-underline text-sm py-1 transition-colors"
          >
            <span>Plataforma Asistencia Personal</span>
            <svg class="w-3.5 h-3.5 shrink-0 opacity-40 group-hover:opacity-80 group-hover:translate-x-0.5 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>

    </div>

    <!-- Copyright -->
    <div class="border-t border-white/20 mt-6 pt-4 sm:mt-8 sm:pt-6 flex flex-col md:flex-row justify-between items-center gap-3">
      <p class="text-white/70 text-xs text-center md:text-left">
        &copy; {new Date().getFullYear()} Asociación de Vida Independiente<br class="md:hidden" /> Andalucía. CIF: G91963124
      </p>
      <div class="flex gap-3 text-xs">
        <a href="/aviso-legal/" class="inline-flex rounded-xl px-3 py-2 bg-white/10 text-white hover:bg-white hover:text-via-green transition-colors no-underline">Aviso Legal</a>
        <a href="/politica-privacidad/" class="inline-flex rounded-xl px-3 py-2 bg-white/10 text-white hover:bg-white hover:text-via-green transition-colors no-underline">Política de Privacidad</a>
      </div>
    </div>
  </div>
</footer>
