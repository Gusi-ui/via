---
type Props = {
  currentPage: number;
  totalPages: number;
  baseUrl: string;
};

const { currentPage, totalPages, baseUrl } = Astro.props;

const pages: (number | '...')[] = [];
for (let i = 1; i <= totalPages; i++) {
  if (i === 1 || i === totalPages || (i >= currentPage - 1 && i <= currentPage + 1)) {
    pages.push(i);
  } else if (pages[pages.length - 1] !== '...') {
    pages.push('...');
  }
}
---

{totalPages > 1 && (
  <nav aria-label="Paginación" class="flex justify-center items-center gap-1 mt-8">
    {currentPage > 1 && (
      <a
        href={`${baseUrl}${currentPage - 1}/`}
        class="px-3 py-2 rounded-lg text-sm text-via-text hover:bg-via-green/10 hover:text-via-green transition-colors no-underline"
        aria-label="Página anterior"
        tabindex="0"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
      </a>
    )}

    {pages.map((page) =>
      page === '...' ? (
        <span class="px-2 py-1 text-via-text-secondary text-sm">...</span>
      ) : (
        <a
          href={`${baseUrl}${page}/`}
          class:list={[
            'px-3 py-1.5 rounded-lg text-sm font-medium transition-colors no-underline',
            page === currentPage
              ? 'bg-via-green text-white'
              : 'text-via-text hover:bg-via-green/10 hover:text-via-green',
          ]}
          aria-current={page === currentPage ? 'page' : undefined}
          aria-label={`Página ${page}`}
          tabindex="0"
        >
          {page}
        </a>
      )
    )}

    {currentPage < totalPages && (
      <a
        href={`${baseUrl}${currentPage + 1}/`}
        class="px-3 py-2 rounded-lg text-sm text-via-text hover:bg-via-green/10 hover:text-via-green transition-colors no-underline"
        aria-label="Página siguiente"
        tabindex="0"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    )}
  </nav>
)}
