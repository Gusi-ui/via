---
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '@components/Breadcrumb.astro';

type Props = {
  title: string;
  description?: string;
  prevArticle?: { title: string; slug: string } | null;
  nextArticle?: { title: string; slug: string } | null;
};

const { title, description, prevArticle, nextArticle } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-8 sm:py-10 md:py-12">
    <Breadcrumb
      items={[
        { label: 'Inicio', href: '/' },
        { label: 'Convención ONU', href: '/convencion/' },
        { label: title },
      ]}
    />

    <article class="bg-via-bg-content rounded-xl shadow-sm p-6 md:p-10 mt-6">
      <header class="mb-8">
        <h1 class="text-2xl md:text-3xl font-bold font-serif text-via-green">
          {title}
        </h1>
      </header>

      <div class="prose max-w-none">
        <slot />
      </div>

      <nav class="mt-10 pt-6 border-t border-via-divider flex flex-col sm:flex-row justify-between gap-4" aria-label="Navegación entre artículos">
        {prevArticle ? (
          <a
            href={`/convencion/${prevArticle.slug}/`}
            class="flex items-center gap-2 text-sm text-via-link hover:text-via-link-hover transition-colors no-underline group"
            aria-label={`Artículo anterior: ${prevArticle.title}`}
          >
            <svg class="w-4 h-4 shrink-0 group-hover:-translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            <span class="line-clamp-1">{prevArticle.title}</span>
          </a>
        ) : <div />}

        {nextArticle ? (
          <a
            href={`/convencion/${nextArticle.slug}/`}
            class="flex items-center gap-2 text-sm text-via-link hover:text-via-link-hover transition-colors no-underline group text-right sm:ml-auto"
            aria-label={`Siguiente artículo: ${nextArticle.title}`}
          >
            <span class="line-clamp-1">{nextArticle.title}</span>
            <svg class="w-4 h-4 shrink-0 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        ) : <div />}
      </nav>
    </article>
  </div>
</BaseLayout>
