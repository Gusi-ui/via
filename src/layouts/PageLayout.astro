---
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '@components/Breadcrumb.astro';

type Props = {
  title: string;
  description?: string;
  breadcrumbs?: Array<{ label: string; href?: string }>;
};

const {
  title,
  description,
  breadcrumbs = [
    { label: 'Inicio', href: '/' },
    { label: title },
  ],
} = Astro.props;
---

<BaseLayout title={title} description={description}>
  <div class="max-w-4xl mx-auto sm:px-4 md:px-6 py-4 sm:py-10 md:py-12">
    <div class="px-4 sm:px-0">
      <Breadcrumb items={breadcrumbs} />
    </div>

    <article class="bg-via-bg-content rounded-none sm:rounded-xl shadow-sm overflow-hidden mt-3 sm:mt-6">
      <div class="p-4 sm:p-6 md:p-10">
        <header class="mb-6 md:mb-8">
          <h1 class="text-2xl md:text-3xl font-bold font-serif text-via-green">
            {title}
          </h1>
        </header>

        <div class="prose max-w-none">
          <slot />
        </div>
      </div>
    </article>
  </div>
</BaseLayout>
