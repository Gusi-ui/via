---
import PageLayout from '@layouts/PageLayout.astro';
import ContactForm from '@components/ContactForm.astro';
---

<PageLayout
  title="Contacto"
  description="Contacta con la Asociación de Vida Independiente Andalucía"
  breadcrumbs={[
    { label: 'Inicio', href: '/' },
    { label: 'Contacto' },
  ]}
>
  <p class="text-via-text mb-2">
    Para cualquier información que desees ponte en contacto con nuestra asociación.
  </p>
  <p class="text-via-text-meta text-sm mb-6">
    Por favor revisa tus datos antes de pulsar en "Enviar" para que podamos responderte a la dirección correcta.
  </p>

  <div class="bg-via-bg-alt rounded-lg p-4 mb-6 text-sm text-via-text-meta">
    <strong>*</strong> Los campos marcados son obligatorios
  </div>

  <ContactForm />

  <div class="mt-10 pt-8 border-t border-via-divider">
    <h2 class="text-xl font-bold font-serif text-via-green mb-4">Información de contacto</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 text-sm text-via-text">
      <div>
        <h3 class="font-semibold mb-1">Dirección</h3>
        <address class="not-italic text-via-text-meta">
          Calle Faustino Álvarez, 41, 1&ordm;<br />
          41002 Sevilla
        </address>
      </div>
      <div>
        <h3 class="font-semibold mb-1">Email</h3>
        <a href="mailto:viandalucia@viandalucia.org" class="text-via-link hover:text-via-link-hover">
          viandalucia@viandalucia.org
        </a>
      </div>
    </div>
  </div>
</PageLayout>
