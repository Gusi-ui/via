---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/Breadcrumb.astro';

// =============================================================================
// IMAGEN DE PORTADA
// -----------------------------------------------------------------------------
// Para añadir la imagen destacada, coloca el archivo en:
//   public/images/pages/documentacion-portada.jpg
// y mantén esta ruta. Mientras no exista la imagen, el script de fallback de
// BaseLayout mostrará el logo por defecto.
// =============================================================================
const coverImage = '/images/pages/documentacion-portada.jpg';

// =============================================================================
// DOCUMENTOS
// -----------------------------------------------------------------------------
// Cada documento puede ser de tipo:
//   - 'page'     → página interna del sitio
//   - 'pdf'      → archivo PDF descargable (colócalo en public/documentos/...)
//   - 'external' → enlace externo (Drive, otra web, etc.)
//
// Para convertir un documento existente en PDF descargable:
//   1. Coloca el PDF en public/documentos/<categoria>/<nombre>.pdf
//   2. Cambia type a 'pdf' y href a '/documentos/<categoria>/<nombre>.pdf'
// =============================================================================

type DocType = 'page' | 'pdf' | 'external';
type Doc = {
  title: string;
  description: string;
  href: string;
  type: DocType;
  author?: string;
};

const visionAndRights: Doc[] = [
  {
    title: 'Diversidad funcional. Visiones encontradas',
    description:
      'Análisis sobre las distintas perspectivas en torno al concepto de diversidad funcional y su impacto en las políticas sociales.',
    href: '/diversidad-funcional-visiones-encontradas/',
    type: 'page',
  },
  {
    title: 'Breve aproximación a las nuevas políticas sociales',
    description:
      'En el ámbito de la diversidad funcional en España. Caminos a seguir para una transformación efectiva.',
    href: '/breve-aproximacion-nuevas-politicas-sociales-ambito-diversidad-funcional-espana-caminos-seguir/',
    type: 'page',
  },
];

const independentLiving: Doc[] = [
  {
    title: 'Vida independiente y asistencia personal',
    description:
      'Los pilares de la filosofía de Vida Independiente y el papel central de la asistencia personal autogestionada.',
    href: '/vida-independiente-y-asistencia-personal/',
    type: 'page',
  },
  {
    title: 'Asistencia personal: Una inversión en derechos',
    description:
      'Una inversión eficiente en empleo. Estudio que demuestra el impacto socioeconómico positivo de la asistencia personal.',
    href: '/asistencia-personal-una-inversion-en-derechos-una-inversion-eficiente-en-empleo/',
    type: 'page',
  },
  {
    title: 'La asistencia personal: un recurso eficiente (Resumen)',
    description:
      'Resumen ejecutivo del estudio sobre la asistencia personal como recurso económicamente eficiente, social y humanamente deseable.',
    href: '/la-asistencia-personal-un-recurso-economicamente-eficiente-social-y-humanamente-deseable-excelente-empleo-resumen/',
    type: 'page',
  },
  {
    title: 'Análisis comparativo de las iniciativas de Vida Independiente',
    description:
      'Estudio comparado de los proyectos y oficinas de Vida Independiente existentes en España.',
    href: '/analisis-comparativo-de-las-iniciativas-de-vida-independiente-en-espana/',
    type: 'page',
  },
  {
    title: 'Recluidos: la privación del derecho a la vida independiente',
    description:
      'Documento sobre la institucionalización y la vulneración del derecho a vivir de forma independiente en la comunidad.',
    href: '/recluidos-la-privacion-del-derecho-a-la-vida-independiente-de-las-personas-con-diversidad-funcional/',
    type: 'page',
  },
  {
    title: 'Asistencia personal vs Ayuda a domicilio',
    description:
      'Comparativa entre los dos modelos de apoyo y sus diferencias fundamentales en cuanto a autonomía y autodeterminación.',
    href: 'https://viandalucia.org/documentos/recursos/APvAD.pdf',
    type: 'external',
  },
];

const inclusiveEducation: Doc[] = [
  {
    title: 'Palabras desde el barro',
    description:
      'Educación inclusiva: una mirada honesta y comprometida sobre los retos de la inclusión real en el sistema educativo.',
    href: '/educacion-inclusiva-palabras-desde-barro/',
    type: 'page',
  },
];

const womenAndDiversity: Doc[] = [
  {
    title: 'Asistencia Personal y empoderamiento de las mujeres',
    description:
      'Asistencia personal y otras herramientas para la equidad y el empoderamiento de las mujeres discriminadas por diversidad funcional. Reclamando el derecho a la Vida Independiente.',
    href: 'https://drive.google.com/file/d/1DSSGVpXF6ojNjJ7k-fBoLSWShRsvO5Fs/view',
    type: 'external',
  },
];

const sections = [
  {
    id: 'vision',
    title: 'Marco conceptual y derechos',
    description:
      'Documentos que abordan el modelo social de la diversidad funcional y las políticas públicas que lo afectan.',
    docs: visionAndRights,
  },
  {
    id: 'vida-independiente',
    title: 'Vida Independiente y Asistencia Personal',
    description:
      'Estudios y materiales sobre la filosofía de Vida Independiente y la asistencia personal autogestionada.',
    docs: independentLiving,
  },
  {
    id: 'educacion',
    title: 'Educación inclusiva',
    description:
      'Recursos sobre el derecho a una educación inclusiva real y de calidad.',
    docs: inclusiveEducation,
  },
  {
    id: 'mujeres',
    title: 'Mujeres y diversidad funcional',
    description:
      'Materiales sobre la situación específica de las mujeres con diversidad funcional.',
    docs: womenAndDiversity,
  },
];

const typeLabels: Record<DocType, string> = {
  page: 'Leer en línea',
  pdf: 'Descargar PDF',
  external: 'Enlace externo',
};
---

<BaseLayout
  title="Documentación recomendada"
  description="Selección de documentos, estudios y materiales sobre Vida Independiente, asistencia personal, derechos y diversidad funcional."
>
  <!-- Portada con imagen y overlay -->
  <div class="relative w-full h-72 sm:h-96 md:h-[28rem] overflow-hidden">
    <img
      src={coverImage}
      alt="Documentación sobre Vida Independiente y diversidad funcional"
      class="w-full h-full object-cover object-center"
      loading="eager"
    />
    <div class="absolute inset-0 bg-black/20"></div>
    <div class="absolute bottom-0 left-0 right-0 bg-black/55 backdrop-blur-sm px-4 sm:px-6 py-4 sm:py-6 md:py-8 overflow-hidden">
      <div class="max-w-5xl mx-auto">
        <p class="text-white/85 text-xs sm:text-sm font-ui tracking-widest uppercase mb-1 font-semibold">
          Biblioteca de recursos
        </p>
        <h1 class="m-0">
          <svg
            viewBox="0 0 100 13"
            class="block w-full h-auto"
            preserveAspectRatio="xMidYMid meet"
            role="img"
            aria-label="Documentación recomendada"
          >
            <text
              x="50"
              y="10"
              text-anchor="middle"
              font-family="Pattaya, system-ui, sans-serif"
              font-size="10"
              font-weight="700"
              font-style="italic"
              fill="#2B843C"
              textLength="99"
              lengthAdjust="spacingAndGlyphs"
            >
              Documentación recomendada
            </text>
          </svg>
        </h1>
      </div>
    </div>
  </div>

  <!-- Contenido -->
  <div class="max-w-4xl mx-auto sm:px-4 md:px-6 py-4 sm:py-8 md:py-10">
    <div class="px-4 sm:px-0">
      <Breadcrumb
        items={[
          { label: 'Inicio', href: '/' },
          { label: 'Documentación' },
        ]}
      />
    </div>

    <article class="bg-via-bg-content rounded-none sm:rounded-xl shadow-sm overflow-hidden mt-3 sm:mt-6">
      <div class="p-4 sm:p-6 md:p-10">

        <!-- Introducción -->
        <section class="prose max-w-none">
          <p class="text-base sm:text-lg text-via-text leading-relaxed">
            Esta es una selección de <strong>documentos, estudios y artículos</strong> que consideramos fundamentales para comprender la filosofía de <strong>Vida Independiente</strong>, la <strong>asistencia personal</strong> y los derechos de las personas con diversidad funcional.
          </p>
          <p class="text-base text-via-text leading-relaxed mt-3">
            Los recursos se agrupan por temáticas. Algunos enlazan a páginas internas con el texto completo, otros son archivos PDF descargables o enlaces a sitios externos.
          </p>
        </section>

        <!-- Secciones de documentos -->
        {sections.map((section) => (
          <section class="mt-10 md:mt-12" id={section.id}>
            <header class="mb-5">
              <h2 class="text-xl md:text-2xl font-bold font-serif text-via-green mb-2">
                {section.title}
              </h2>
              <p class="text-via-text-secondary text-sm sm:text-base leading-relaxed">
                {section.description}
              </p>
            </header>

            <ul class="flex flex-col gap-3">
              {section.docs.map((doc) => (
                <li>
                  <a
                    href={doc.href}
                    target={doc.type === 'external' || doc.type === 'pdf' ? '_blank' : undefined}
                    rel={doc.type === 'external' || doc.type === 'pdf' ? 'noopener noreferrer' : undefined}
                    class="group flex gap-4 items-start p-4 rounded-xl border border-via-divider bg-via-bg-content hover:border-via-green/30 hover:shadow-md transition-all no-underline"
                  >
                    <span class="mt-0.5 shrink-0 flex items-center justify-center w-10 h-10 rounded-lg bg-via-green/10 group-hover:bg-via-green/20 transition-colors">
                      {doc.type === 'pdf' && (
                        <svg class="w-5 h-5 text-via-green" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                          <polyline points="14 2 14 8 20 8"/>
                          <line x1="9" y1="15" x2="15" y2="15"/>
                          <line x1="9" y1="18" x2="13" y2="18"/>
                        </svg>
                      )}
                      {doc.type === 'page' && (
                        <svg class="w-5 h-5 text-via-green" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
                          <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
                        </svg>
                      )}
                      {doc.type === 'external' && (
                        <svg class="w-5 h-5 text-via-green" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                          <polyline points="15 3 21 3 21 9"/>
                          <line x1="10" y1="14" x2="21" y2="3"/>
                        </svg>
                      )}
                    </span>
                    <div class="flex-1 min-w-0">
                      <p class="font-semibold text-via-text text-sm sm:text-base group-hover:text-via-green transition-colors">
                        {doc.title}
                      </p>
                      <p class="text-via-text-secondary text-sm leading-relaxed mt-1">
                        {doc.description}
                      </p>
                      <p class="text-xs text-via-green font-semibold mt-2 flex items-center gap-1">
                        {typeLabels[doc.type]}
                        <svg class="w-3 h-3 group-hover:translate-x-0.5 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <path d="M5 12h14M12 5l7 7-7 7"/>
                        </svg>
                      </p>
                    </div>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        ))}

        <!-- Divisor -->
        <hr class="border-via-divider my-10 md:my-12" />

        <!-- Tarjeta destacada: Convención ONU -->
        <section>
          <h2 class="text-xl md:text-2xl font-bold font-serif text-via-green mb-5">
            Marco internacional
          </h2>
          <a
            href="/convencion-naciones-unidas-personas-con-discapacidad/"
            class="group block relative overflow-hidden rounded-2xl border-2 border-via-green/25 bg-gradient-to-br from-via-green/5 via-via-green/8 to-via-green/15 hover:border-via-green/50 hover:shadow-lg transition-all no-underline"
          >
            <div class="flex flex-col sm:flex-row items-center sm:items-start gap-4 sm:gap-5 p-5 sm:p-6 md:p-7">
              <div class="shrink-0 w-24 h-24 sm:w-28 sm:h-28 md:w-32 md:h-32 rounded-full bg-white shadow-sm ring-1 ring-via-green/10 flex items-center justify-center">
                <img
                  src="/images/pages/pequenaciones.png"
                  alt="Logotipo de las Naciones Unidas"
                  class="w-16 sm:w-20 md:w-24 h-auto object-contain"
                  loading="lazy"
                />
              </div>
              <div class="flex-1 min-w-0 text-center sm:text-left">
                <p class="text-[11px] font-semibold tracking-widest uppercase text-via-green mb-1.5">
                  Naciones Unidas
                </p>
                <h3 class="text-base sm:text-lg md:text-xl font-bold font-serif text-via-text group-hover:text-via-green transition-colors leading-snug mb-2 break-words">
                  Convención sobre los derechos de las personas con diversidad funcional
                </h3>
                <p class="text-via-text-secondary text-sm leading-relaxed mb-3">
                  El texto íntegro, artículo por artículo, con el preámbulo y todas sus disposiciones.
                </p>
                <span class="inline-flex items-center gap-1.5 text-xs sm:text-sm font-semibold text-via-green">
                  Consultar la Convención
                  <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                  </svg>
                </span>
              </div>
            </div>
          </a>
        </section>

      </div>
    </article>
  </div>
</BaseLayout>
