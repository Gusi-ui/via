---
import PageLayout from '@layouts/PageLayout.astro';
import { getConventionPages } from '@/lib/collections';

const articles = await getConventionPages();
const preambulo = articles.find((a) => a.id.includes('preambulo'));
const numbered = articles.filter(
  (a) => !a.id.includes('convencion-naciones-unidas') && !a.id.includes('preambulo')
);
---

<PageLayout
  title="Convención de Naciones Unidas"
  description="Texto íntegro de la Convención de Naciones Unidas sobre los derechos de las personas con diversidad funcional, artículo por artículo."
  coverImage="/images/pages/convencion-portada.jpg"
  coverEyebrow="Marco internacional"
  coverTitle="Convención ONU"
  breadcrumbs={[
    { label: 'Inicio', href: '/' },
    { label: 'Convención ONU' },
  ]}
>
  <p class="text-via-text-secondary text-base sm:text-lg leading-relaxed mb-2">
    Convención sobre los derechos de las personas con diversidad funcional (discapacidad).
  </p>
  <p class="text-via-text leading-relaxed mb-6">
    Accede a la lectura del documento vía web, o descarga las versiones en formato de fácil lectura y sistema pictográfico de comunicación.
  </p>

  <!-- Botones de descarga -->
  <div class="flex flex-wrap gap-3 mb-10">
    <a
      href="https://viandalucia.org/wp-content/uploads/2019/05/Convencion-Lectura-Facil.pdf"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 px-4 py-2.5 bg-via-green text-white text-sm font-semibold rounded-xl border border-via-green hover:bg-white hover:text-via-green transition-colors no-underline focus:outline-none focus:ring-2 focus:ring-via-green/40"
      tabindex="0"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
      </svg>
      Fácil Lectura (PDF)
    </a>
    <a
      href="https://viandalucia.org/wp-content/uploads/2019/05/Convencion-pictogramas.pdf"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 px-4 py-2.5 bg-white text-via-green text-sm font-semibold rounded-xl border border-via-green hover:bg-via-green hover:text-white transition-colors no-underline focus:outline-none focus:ring-2 focus:ring-via-green/40"
      tabindex="0"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
      </svg>
      Sistema Pictográfico (PDF)
    </a>
  </div>

  <!-- Listado de artículos -->
  <h2 class="text-xl md:text-2xl font-bold font-serif text-via-green mb-4 mt-2 not-prose">
    Texto íntegro
  </h2>

  <div class="not-prose flex flex-col gap-1">
    {preambulo && (
      <a
        href={`/convencion/${preambulo.id}/`}
        class="group flex items-center gap-3 px-4 py-3 rounded-lg border border-via-divider bg-via-bg-content hover:border-via-green/30 hover:bg-via-green/5 transition-all no-underline"
        tabindex="0"
      >
        <span class="shrink-0 inline-flex items-center justify-center text-xs font-bold text-via-green bg-via-green/10 w-9 h-9 rounded-full">
          §
        </span>
        <span class="font-semibold text-via-text group-hover:text-via-green transition-colors">
          {preambulo.data.title}
        </span>
      </a>
    )}

    {numbered.map((article, i) => (
      <a
        href={`/convencion/${article.id}/`}
        class="group flex items-center gap-3 px-4 py-3 rounded-lg border border-via-divider bg-via-bg-content hover:border-via-green/30 hover:bg-via-green/5 transition-all no-underline"
        tabindex="0"
      >
        <span class="shrink-0 inline-flex items-center justify-center text-xs font-bold text-via-green bg-via-green/10 w-9 h-9 rounded-full">
          {i + 1}
        </span>
        <span class="text-sm sm:text-base font-medium text-via-text group-hover:text-via-green transition-colors">
          {article.data.title}
        </span>
      </a>
    ))}
  </div>
</PageLayout>
