---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/Breadcrumb.astro';

const partners = [
  {
    name: 'OVIAndalucía',
    location: 'Andalucía',
    description: 'Asociación de Vida Independiente Andalucía, promotora de la asistencia personal autogestionada en la comunidad.',
    href: '/nosotros/',
    logo: '/images/pages/oviandalucia-min-1-1024x486.jpg',
  },
  {
    name: 'OVI Barcelona',
    location: 'Barcelona',
    description: 'Creada en torno al proyecto "Hacia la Vida Independiente", gestionada con el Instituto Municipal de Personas con Discapacidad.',
    href: 'https://federacionvi.org/miembros/ovi-de-barcelona',
    logo: '/images/pages/ovi_barcelona-min.jpg',
    external: true,
  },
  {
    name: 'VIGalicia',
    location: 'Galicia',
    description: 'Primera asociación de usuarios y usuarias de asistencia personal de España. Cada miembro autogestiona su asistencia.',
    href: 'https://federacionvi.org/miembros/vigalicia',
    logo: '/images/pages/vigalicia.jpg',
    external: true,
  },
  {
    name: 'OVICanarias',
    location: 'Canarias',
    description: 'Oficina de Vida Independiente en las Islas Canarias, promoviendo los derechos de las personas con diversidad funcional.',
    href: 'https://www.ovicanarias.org/',
    logo: '/images/pages/ovicanarias-min-1-1024x486.jpg',
    external: true,
  },
  {
    name: 'ZAVI',
    location: 'Zaragoza',
    description: 'Zaragoza de Vida Independiente, impulsando la autonomía personal y la asistencia personal en Aragón.',
    href: 'https://zavizgz.wordpress.com/',
    logo: '/images/pages/logo-zavi-min-1-1024x486.jpg',
    external: true,
  },
  {
    name: 'VICOVAL',
    location: 'Com. Valenciana',
    description: 'Vida Independiente de la Comunitat Valenciana, trabajando por la plena inclusión y la asistencia personal.',
    href: 'http://vicoval.org/',
    logo: '/images/pages/vicoval-min.jpg',
    external: true,
  },
];

const services = [
  {
    title: 'Asistencia Personal autogestionada',
    description: 'Los participantes tienen libertad para elegir, formar, dirigir y despedir a sus asistentes personales. La contratación corre a cargo de la OVI.',
  },
  {
    title: 'Apoyo entre iguales',
    description: 'Espacio de intercambio de experiencias y formación entre personas con diversidad funcional, a través de videoconferencias y contacto directo.',
  },
  {
    title: 'Asesoramiento en derechos',
    description: 'Orientación e intervención en materia de derechos de las personas con diversidad funcional, con especial atención a la Convención ONU.',
  },
  {
    title: 'Difusión de la Vida Independiente',
    description: 'Formación y sensibilización sobre la filosofía de Vida Independiente: autonomía, empoderamiento y autodeterminación.',
  },
];
---

<BaseLayout
  title="Oficinas de Vida Independiente"
  description="Qué es una Oficina de Vida Independiente (OVI), qué servicios ofrece OVIAndalucía y la red de OVIs existentes en España."
>
  <!-- Portada con imagen y overlay -->
  <div class="relative w-full h-64 sm:h-80 md:h-96 overflow-hidden">
    <img
      src="/images/pages/oviaportada.jpg"
      alt="Personas con diversidad funcional en un acto de OVIAndalucía"
      class="w-full h-full object-cover object-center"
      loading="eager"
    />
    <div class="absolute inset-0 bg-black/20"></div>
    <div class="absolute bottom-0 left-0 right-0 bg-black/70 backdrop-blur-sm px-4 sm:px-6 py-5 sm:py-7">
      <div class="max-w-4xl mx-auto">
        <p class="text-white/80 text-sm sm:text-base font-ui tracking-widest uppercase mb-2">Red de organizaciones</p>
        <h1 class="font-display italic font-bold text-white text-[clamp(2.6rem,8vw,4.5rem)] leading-tight">
          Oficinas de Vida Independiente
        </h1>
      </div>
    </div>
  </div>

  <!-- Contenido -->
  <div class="max-w-4xl mx-auto sm:px-4 md:px-6 py-4 sm:py-8 md:py-10">
    <div class="px-4 sm:px-0">
      <Breadcrumb
        items={[
          { label: 'Inicio', href: '/' },
          { label: 'Oficinas de VI' },
        ]}
      />
    </div>

    <article class="bg-via-bg-content rounded-none sm:rounded-xl shadow-sm overflow-hidden mt-3 sm:mt-6">
      <div class="p-4 sm:p-6 md:p-10">

        <!-- Definición -->
        <section class="prose max-w-none">
          <p class="text-base sm:text-lg text-via-text leading-relaxed">
            Una <strong>Oficina de Vida Independiente (OVI)</strong> es una entidad <em>por y para</em> el empoderamiento de las personas con diversidad funcional que la constituyen. Es un espacio entre iguales de formación y emancipación, y una herramienta para gestionar la contratación de <strong>Asistencia Personal</strong> y los proyectos de vida a nivel administrativo y legal.
          </p>
          <p class="text-base text-via-text leading-relaxed mt-3">
            El programa abarca diversidad física e intelectual y está orientado a que cada persona pueda diseñar y dirigir su propio proyecto de vida con plena autonomía.
          </p>
        </section>

        <!-- Servicios -->
        <section class="mt-8 md:mt-10">
          <h2 class="text-xl md:text-2xl font-bold font-serif text-via-green mb-5">
            Qué ofrece la OVI de VIAndalucía
          </h2>
          <ul class="flex flex-col gap-4">
            {services.map((s) => (
              <li class="flex gap-4 items-start">
                <span class="mt-0.5 shrink-0 flex items-center justify-center w-6 h-6 rounded-full bg-via-green/10">
                  <svg class="w-3.5 h-3.5 text-via-green" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M20 6 9 17l-5-5"/>
                  </svg>
                </span>
                <div>
                  <p class="font-semibold text-via-text text-sm sm:text-base">{s.title}</p>
                  <p class="text-via-text-secondary text-sm leading-relaxed mt-0.5">{s.description}</p>
                </div>
              </li>
            ))}
          </ul>
        </section>

        <!-- Divisor -->
        <hr class="border-via-divider my-8 md:my-10" />

        <!-- Red de OVIs -->
        <section>
          <h2 class="text-xl md:text-2xl font-bold font-serif text-via-green mb-2">
            Red de OVIs en España
          </h2>
          <p class="text-via-text-secondary text-sm sm:text-base leading-relaxed mb-6">
            Actualmente existen seis OVIs agrupadas en torno a la{' '}
            <a href="https://federacionvi.org/" target="_blank" rel="noopener noreferrer" class="text-via-green font-medium hover:underline">
              Federación VI
            </a>{' '}
            con objetivos comunes pero estructuras diferentes, adaptadas a las necesidades de cada territorio.
          </p>

          <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
            {partners.map((p) => (
              <a
                href={p.href}
                target={p.external ? '_blank' : undefined}
                rel={p.external ? 'noopener noreferrer' : undefined}
                class="group flex flex-col rounded-xl border border-via-divider bg-via-bg-content overflow-hidden no-underline hover:shadow-md hover:border-via-green/30 transition-all"
              >
                <div class="aspect-[16/7] overflow-hidden bg-via-bg-alt">
                  <img
                    src={p.logo}
                    alt={`Logo ${p.name}`}
                    class="w-full h-full object-contain p-3 group-hover:scale-105 transition-transform duration-300"
                    loading="lazy"
                  />
                </div>
                <div class="p-3 flex-1 flex flex-col gap-1">
                  <div class="flex items-center justify-between gap-2">
                    <span class="font-semibold text-via-text text-sm group-hover:text-via-green transition-colors">{p.name}</span>
                    <span class="text-xs text-via-text-secondary bg-via-bg-alt px-2 py-0.5 rounded-full shrink-0">{p.location}</span>
                  </div>
                  <p class="text-xs text-via-text-secondary leading-relaxed">{p.description}</p>
                </div>
              </a>
            ))}
          </div>
        </section>

      </div>
    </article>
  </div>
</BaseLayout>
