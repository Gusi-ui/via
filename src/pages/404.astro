---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="Página no encontrada">
  <div class="max-w-2xl mx-auto px-4 py-20 text-center">
    <p class="text-6xl font-bold text-via-green/20 font-display mb-4">404</p>
    <h1 class="text-2xl md:text-3xl font-bold font-serif text-via-green mb-4">
      Página no encontrada
    </h1>
    <p class="text-via-text-meta mb-8">
      Lo sentimos, la página que buscas no existe o ha sido movida.
    </p>
    <a
      href="/"
      class="inline-flex items-center gap-2 px-6 py-3 bg-via-green text-white font-semibold rounded-xl border border-via-green hover:bg-white hover:text-via-green transition-colors no-underline focus:outline-none focus:ring-2 focus:ring-via-green/40"
      tabindex="0"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
      </svg>
      Volver al inicio
    </a>
  </div>
</BaseLayout>
